@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor LOGIC_COLOR_T4
skinparam classBackgroundColor LOGIC_COLOR

package Logic as LogicPackage {

Class "<<interface>>\nLogic" as Logic
Class LogicManager

package "Parser Classes" as ParserClasses {
    Class AddressBookParser
    Class XYZCommandParser
}

package "Command Classes" as CommandClasses {
    Class XYZCommand
    Class CommandResult
    Class "{abstract}\nCommand" as Command
}

}

package Model {
Class HiddenModel #FFFFFF
}

package Storage {
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Logic

LogicManager .right.|> Logic
LogicManager -right-> AddressBookParser
AddressBookParser ..> XYZCommandParser : <<create>>
XYZCommandParser ..> XYZCommand : <<create>>

XYZCommand -up-|> Command
LogicManager .left.> Command : <<call>>

LogicManager --> Model
LogicManager --> Storage
Storage --[hidden] Model
Command .[hidden]up.> Storage
Command .right.> Model

note right of XYZCommand
    XYZCommand =
    AddCommand,
    DeleteCommand,
    FindCommand,
    ListCommand,
    RenewMembershipCommand,
    etc.
end note

note right of XYZCommandParser
    XYZCommandParser =
    AddCommandParser,
    DeleteCommandParser,
    FindCommandParser,
    RenewMembershipCommandParser,
    etc.
end note

Logic ..> CommandResult
LogicManager .down.> CommandResult
Command .up.> CommandResult : <<create>>
@enduml